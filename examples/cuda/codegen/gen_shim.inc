// cuMemPoolCreate | barrier
CUresult cuMemPoolCreate(CUmemGenericAllocationHandle* pool, void* poolProps) {
    init_shim();
    if (!g_initialized) return CUDA_ERROR_NOT_INITIALIZED;
    auto ret = cuda_rpc_call<func_index::mem_pool_create>(poolProps);
    if (ret.result == CUDA_SUCCESS && ret.pool != 0) {
        uint64_t client_handle = allocate_client_handle("mempool");
        register_handle(client_handle, ret.pool, "mempool");
        *pool = reinterpret_cast<CUmemGenericAllocationHandle>(client_handle);
    }
    return static_cast<CUresult>(ret.result);
}

